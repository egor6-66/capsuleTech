ignore-workspace-root-check=true

# Default registry — публичный npm. Используется для всего, кроме @capsule.
registry=https://registry.npmjs.org/

# @capsule идёт в локальный Verdaccio (для тестов nx-release).
# Внутри этого репо @capsule/* резолвятся как workspace:* и регистр не дёргают.
# В чужом workspace эта строка имеет смысл только когда Verdaccio запущен
# (см. `pnpm registry` в scripts/) — иначе достаточно убрать её или
# перевести @capsule:registry на публичный npm.
@capsule:registry=http://localhost:4876/
//localhost:4876/:_authToken=secretVerdaccioToken
