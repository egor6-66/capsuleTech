/.verdaccio
# Local Claude Code state — local-only.
.claude/worktrees
.claude/settings.local.json
# Per-instance settings inside any nested .claude/ (e.g. docker/observability/.claude/).
**/.claude/settings.local.json
# Main-session marker (host/session-specific) — written by SessionStart hook,
# read by git-gate.mjs to grant write-git only to the main session.
**/.claude/.main-session-id
# NOTE: .claude/agents/ is TRACKED — shared agent prompts for the team.

# Local test/playground apps inside monorepo — workspace-mode framework dev,
# not framework-developer scope (apps/ otherwise tracked). Used to debug
# framework changes without publish-cycle. Personal, never committed.
/apps/sandbox/

# Auto-generated by capsule vite-builder plugins (RouterPlugin, ExportGenerator,
# EnsureScaffold, AppConfigPlugin). Каждый app получает свой .capsule/ при dev,
# содержимое детерминировано из src/ → коммитить не нужно.
apps/*/.capsule/

# Auto-generated by @capsuletech/docs build (ADR 052 Phase 3).
# Formerly generated by docs/_build/extract.mjs (ADR 048 E1).
# Содержимое детерминировано из docs/**/*.md → коммитить не нужно (CI регенерирует).
docs/.generated/

.nx/polygraph
ctx
.aider*
/ww
# Smart Environment plugin
.smart-env

# Стейл-артефакты от IDE-овского tsc auto-compile (на всякий случай — даже если IDE
# настройка вернётся, git их не подхватит).
apps/*/src/**/*.js
apps/*/src/**/*.jsx
packages/*/src/**/*.js
packages/*/src/**/*.jsx
packages/*/*/src/**/*.js
packages/*/*/src/**/*.jsx
nexus-uk.conf
# Nx-граф dump — артефакт, регенерится по запросу
graph.json

# Secrets / env — NEVER commit
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials*.json
secrets*.json
# VPN / tunnel configs (WireGuard/OpenVPN — contain private keys)
*.conf
*.ovpn
# ...но nginx-конфиг dev-gateway (ADR 068 D6) — код, не секрет
!docker/gateway/nginx.conf
