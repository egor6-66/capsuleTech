{
  "name": "@capsuletech/web-date",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./format": {
      "types": "./dist/format.d.ts",
      "import": "./dist/format.mjs",
      "default": "./dist/format.mjs"
    },
    "./filters": {
      "types": "./dist/filters.d.ts",
      "import": "./dist/filters.mjs",
      "default": "./dist/filters.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "date-fns": "^4.4.0"
  },
  "devDependencies": {
    "@capsuletech/lib-builder": "workspace:*",
    "@capsuletech/vite-builder": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "packageManager": "pnpm"
  }
}
