{
  "name": "@capsuletech/web-studio",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./manifests": {
      "types": "./dist/shared/manifests/index.d.ts",
      "import": "./dist/manifests.mjs",
      "default": "./dist/manifests.mjs"
    },
    "./capsule": {
      "types": "./dist/capsule.d.ts",
      "import": "./dist/capsule.mjs",
      "default": "./dist/capsule.mjs"
    },
    "./palette": {
      "types": "./dist/modules/palette/index.d.ts",
      "import": "./dist/palette.mjs",
      "default": "./dist/palette.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capsuletech/data-gen": "workspace:*",
    "@capsuletech/shared-zod": "workspace:*",
    "@capsuletech/web-docs": "workspace:*",
    "@capsuletech/web-contract": "workspace:*",
    "@capsuletech/web-core": "workspace:*",
    "@capsuletech/web-dnd": "workspace:*",
    "@capsuletech/web-placeholders": "workspace:*",
    "@capsuletech/web-remote": "workspace:*",
    "@capsuletech/web-router": "workspace:*",
    "@capsuletech/web-shell": "workspace:*",
    "@capsuletech/web-style": "workspace:*",
    "@capsuletech/web-ui": "workspace:*"
  },
  "peerDependencies": {
    "@capsuletech/web-renderer": "workspace:*",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@capsuletech/lib-builder": "workspace:*",
    "@capsuletech/vite-builder": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "~29.1.1",
    "vite-plugin-solid": "^2.11.13"
  },
  "publishConfig": {
    "access": "public",
    "packageManager": "pnpm"
  }
}
