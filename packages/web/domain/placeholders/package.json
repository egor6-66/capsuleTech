{
  "name": "@capsuletech/web-placeholders",
  "version": "0.0.0",
  "description": "Ходовые плейсхолдеры экосистемы (404 / error / access-denied / community / widget-unavailable) как готовые Placeholders.* блоки. Iter 1 — на kit-компонентах; линия renderer-конвергенции (схемы web-renderer) — фаза 2.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./capsule": {
      "types": "./dist/capsule.d.ts",
      "import": "./dist/capsule.mjs",
      "default": "./dist/capsule.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capsuletech/web-core": "workspace:*",
    "@capsuletech/web-ui": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@capsuletech/lib-builder": "workspace:*",
    "@capsuletech/vite-builder": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "~29.1.1",
    "vite-plugin-solid": "^2.11.13"
  },
  "publishConfig": {
    "access": "public",
    "packageManager": "pnpm"
  }
}
