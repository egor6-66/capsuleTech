{
  "name": "@capsuletech/web-shell",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui.mjs",
      "default": "./dist/ui.mjs"
    },
    "./controllers": {
      "types": "./dist/controllers/index.d.ts",
      "import": "./dist/controllers.mjs",
      "default": "./dist/controllers.mjs"
    },
    "./capsule": {
      "types": "./dist/capsule.d.ts",
      "import": "./dist/capsule.mjs",
      "default": "./dist/capsule.mjs"
    },
    "./chrome": {
      "types": "./dist/chrome/index.d.ts",
      "import": "./dist/chrome.mjs",
      "default": "./dist/chrome.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capsuletech/web-core": "workspace:*",
    "@capsuletech/web-intl": "workspace:*",
    "@capsuletech/web-style": "workspace:*",
    "@capsuletech/web-ui": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@capsuletech/lib-builder": "workspace:*",
    "@capsuletech/vite-builder": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "~29.1.1",
    "vite-plugin-solid": "^2.11.12"
  },
  "publishConfig": {
    "access": "public",
    "packageManager": "pnpm"
  }
}
