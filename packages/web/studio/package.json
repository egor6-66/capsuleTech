{
  "name": "@capsuletech/web-studio",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./manifests": {
      "types": "./dist/manifests/index.d.ts",
      "import": "./dist/manifests.mjs",
      "default": "./dist/manifests.mjs"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state.mjs",
      "default": "./dist/state.mjs"
    },
    "./inspector": {
      "types": "./dist/inspector/index.d.ts",
      "import": "./dist/inspector.mjs",
      "default": "./dist/inspector.mjs"
    },
    "./generators": {
      "types": "./dist/generators/index.d.ts",
      "import": "./dist/generators.mjs",
      "default": "./dist/generators.mjs"
    },
    "./controllers": {
      "types": "./dist/controllers/index.d.ts",
      "import": "./dist/controllers.mjs",
      "default": "./dist/controllers.mjs"
    },
    "./capsule": {
      "types": "./dist/capsule.d.ts",
      "import": "./dist/capsule.mjs",
      "default": "./dist/capsule.mjs"
    },
    "./docs": {
      "types": "./dist/docs/index.d.ts",
      "import": "./dist/docs.mjs",
      "default": "./dist/docs.mjs"
    },
    "./palette": {
      "types": "./dist/palette/index.d.ts",
      "import": "./dist/palette.mjs",
      "default": "./dist/palette.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capsuletech/data-gen": "workspace:*",
    "@capsuletech/shared-zod": "workspace:*",
    "@capsuletech/web-core": "workspace:*",
    "@capsuletech/web-dnd": "workspace:*",
    "@capsuletech/web-ui": "workspace:*",
    "marked": "^9.1.6"
  },
  "peerDependencies": {
    "@capsuletech/web-renderer": "workspace:*",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@capsuletech/lib-builder": "workspace:*",
    "@capsuletech/vite-builder": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "~29.1.1",
    "vite-plugin-solid": "^2.11.12"
  },
  "publishConfig": {
    "access": "public",
    "packageManager": "pnpm"
  }
