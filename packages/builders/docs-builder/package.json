{
  "name": "@capsuletech/docs-builder",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "bin": {
    "capsule-docs": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vite-plugin-dts": "~5.0.0"
  },
  "devDependencies": {
    "@vue/language-core": "~3.1.5"
  },
  "publishConfig": {
    "access": "public",
    "packageManager": "pnpm"
  }
}
