{
  "name": "@capsuletech/shared-file-manager",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@nx/devkit": "^22.7.0",
    "jiti": "2.4.2",
    "nx": "22.7.2"
  },
  "devDependencies": {
    "@capsuletech/lib-builder": "workspace:*",
    "@capsuletech/vite-builder": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "packageManager": "pnpm"
  }
}
