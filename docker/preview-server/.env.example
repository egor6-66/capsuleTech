# Скопируй в .env и заполни. .env читается docker-compose.yml.

# ОБЯЗАТЕЛЬНО. Токен, который deploy-клиент шлёт в Authorization: Bearer <token>.
# Любая длинная случайная строка. Без него deploy отключён (POST → 503).
DEPLOY_TOKEN=change-me-to-a-long-random-string

# Необязательно. Host/IP, по которому тестеры открывают превью (для ссылок в
# ответе deploy и на лендинге). Пусто → выводится из Host-хедера запроса.
# Пример: PUBLIC_HOST=preview.intranet.local  или  PUBLIC_HOST=10.0.0.5
PUBLIC_HOST=
