{
  "uid": "capsule-fleet",
  "title": "Capsule — Agent Fleet",
  "tags": ["capsule", "agents"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "scope",
        "label": "Scope",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(scope)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Event rate by scope",
      "description": "События Claude Code (tool_result/api_request/user_prompt) в секунду, по скоупам.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (scope) (count_over_time({scope=~\"$scope\"} [$__auto]))",
          "queryType": "range",
          "legendFormat": "{{scope}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active scopes",
      "description": "Скоупы, от которых пришли события в окне.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (scope) (count_over_time({scope=~\"$scope\"} [$__range]))",
          "queryType": "instant",
          "legendFormat": "{{scope}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Token usage rate by scope",
      "description": "Prometheus-метрика claude_code_token_usage_tokens_total (подтверждено на smoke). Разбивка по type — input/output/cacheRead/cacheCreation.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (scope) (rate(claude_code_token_usage_tokens_total[$__rate_interval]))",
          "legendFormat": "{{scope}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Event stream",
      "description": "Сырой поток событий по выбранным скоупам. tool_name / prompt — в structured metadata (раскрыть строку).",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "enableLogDetails": true, "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{scope=~\"$scope\"}",
          "queryType": "range"
        }
      ]
    }
  ]
}
