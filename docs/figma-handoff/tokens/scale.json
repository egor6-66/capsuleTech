{
  "$description": "Theme-independent scale (spacing, radii, typography, motion, status). Общий слой: НЕ меняется между темами. Значения сняты при density=1, radius-anchor=0.5rem (8px).",

  "space": {
    "$description": "Геометрическая шкала отступов (Tailwind --spacing). В коде p-1 = 1×base. Здесь — абсолютные px при density=1.",
    "0": { "$type": "dimension", "$value": "0px" },
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" }
  },

  "spacing-semantic": {
    "$description": "Семантические отступы (density-aware в коде). Здесь — при density=1. Компоненты используют их, а не сырую шкалу.",
    "cell-tight": { "$type": "dimension", "$value": "8px" },
    "cell": { "$type": "dimension", "$value": "12px" },
    "cell-loose": { "$type": "dimension", "$value": "16px" },
    "button-sm": { "$type": "dimension", "$value": "8px" },
    "button": { "$type": "dimension", "$value": "12px" },
    "button-lg": { "$type": "dimension", "$value": "16px" },
    "input": { "$type": "dimension", "$value": "12px" },
    "field": { "$type": "dimension", "$value": "8px" },
    "card": { "$type": "dimension", "$value": "24px" },
    "card-tight": { "$type": "dimension", "$value": "16px" },
    "section": { "$type": "dimension", "$value": "32px" },
    "layout": { "$type": "dimension", "$value": "16px" },
    "component": { "$type": "dimension", "$value": "12px" },
    "tight": { "$type": "dimension", "$value": "8px" },
    "slot": { "$type": "dimension", "$value": "48px" }
  },

  "radius": {
    "$description": "Ладдер скруглений, привязан к radius-anchor темы. Здесь — при anchor=0.5rem (8px). Если тема меняет --radius, вся шкала сдвигается.",
    "xs": { "$type": "dimension", "$value": "2px" },
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "6px" },
    "lg": { "$type": "dimension", "$value": "8px" },
    "xl": { "$type": "dimension", "$value": "12px" },
    "2xl": { "$type": "dimension", "$value": "16px" },
    "3xl": { "$type": "dimension", "$value": "24px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },

  "font-size": {
    "$description": "Размеры шрифта (Tailwind text-*).",
    "xs": { "$type": "dimension", "$value": "12px" },
    "sm": { "$type": "dimension", "$value": "14px" },
    "base": { "$type": "dimension", "$value": "16px" },
    "lg": { "$type": "dimension", "$value": "18px" },
    "xl": { "$type": "dimension", "$value": "20px" },
    "2xl": { "$type": "dimension", "$value": "24px" },
    "3xl": { "$type": "dimension", "$value": "30px" },
    "4xl": { "$type": "dimension", "$value": "36px" },
    "5xl": { "$type": "dimension", "$value": "48px" }
  },

  "line-height": {
    "$description": "Межстрочные (Tailwind leading-*). Безразмерные множители.",
    "none": { "$type": "number", "$value": 1 },
    "tight": { "$type": "number", "$value": 1.2 },
    "snug": { "$type": "number", "$value": 1.375 },
    "normal": { "$type": "number", "$value": 1.5 },
    "relaxed": { "$type": "number", "$value": 1.7 },
    "loose": { "$type": "number", "$value": 2 }
  },

  "letter-spacing": {
    "$description": "Трекинг (Tailwind tracking-*), относительно tracking-normal темы. Здесь — при базе 0em.",
    "tighter": { "$type": "dimension", "$value": "-0.05em" },
    "tight": { "$type": "dimension", "$value": "-0.025em" },
    "normal": { "$type": "dimension", "$value": "0em" },
    "wide": { "$type": "dimension", "$value": "0.025em" },
    "wider": { "$type": "dimension", "$value": "0.05em" },
    "widest": { "$type": "dimension", "$value": "0.1em" }
  },

  "easing": {
    "$description": "Кривые анимации (Tailwind ease-*). Длительности в Figma не нужны — это runtime-концепт (в коде numeric: duration-200 = 200ms, duration-[320ms] = 320ms).",
    "linear": { "$type": "cubicBezier", "$value": [0, 0, 1, 1] },
    "in": { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1] },
    "out": { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] },
    "in-out": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] },
    "spring": { "$type": "cubicBezier", "$value": [0.5, 1.25, 0.75, 1.25] },
    "bounce": { "$type": "cubicBezier", "$value": [0.34, 1.56, 0.64, 1] }
  },

  "status": {
    "$description": "Семантические статусы (theme-independent дефолты). success/warning + контрастные foreground. error = используйте destructive из темы.",
    "success": { "$type": "color", "$value": "#00a63e" },
    "success-foreground": { "$type": "color", "$value": "#fafafa" },
    "warning": { "$type": "color", "$value": "#fe9a00" },
    "warning-foreground": { "$type": "color", "$value": "#0a0a0a" }
  }
}
