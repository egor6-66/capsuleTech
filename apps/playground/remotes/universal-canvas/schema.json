{
  "in": {
    "setMarkers": {
      "type": "object",
      "properties": {
        "markers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "lat": {
                "type": "number",
                "minimum": -90,
                "maximum": 90
              },
              "lng": {
                "type": "number",
                "minimum": -180,
                "maximum": 180
              }
            },
            "required": [
              "id",
              "lat",
              "lng"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "markers"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  "out": {
    "mounted": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "ts": {
          "type": "number"
        }
      },
      "required": [
        "name",
        "ts"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  }
}
