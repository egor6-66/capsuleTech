# capsule-playground — локальные настройки.
# Скопируй в `.env` (его читает dotenvy при `cargo run`) или экспортируй руками.
# В проде/закрытом контуре переменные приходят из реального окружения.

DATABASE_URL=postgres://capsule:capsule@localhost:5433/capsule_playground
REDIS_URL=redis://localhost:6380
PLAYGROUND_BIND=127.0.0.1:8080
DATA_DIR=./_data

# Bearer-токен для приёма deploy (POST /api/deploy). Пусто → deploy отключён.
DEPLOY_TOKEN=
