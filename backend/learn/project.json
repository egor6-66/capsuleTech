{
  "name": "backend-learn",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "backend/learn/src",
  "tags": ["backend", "python", "learn"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend/learn",
        "command": "uv run uvicorn capsule_learn.main:app --port 8003 --reload"
      }
    },
    "warm-voice": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend/learn",
        "command": "uv run python -m capsule_learn.warm"
      }
    },
    "test:py": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend/learn",
        "command": "uv run pytest"
      }
    },
    "lint:py": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend/learn",
        "command": "uv run ruff check ."
      }
    }
  }
}
